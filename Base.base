views:
  - type: table
    name: Base
    order:
      - file.name
      - file.tags
      - file.folder
      - file.links
      - title
      - summary
    columnSize:
      file.folder: 114
  - type: cards
    name: View
    order:
      - file.name
      - file.tags
      - file.path
      - file.backlinks
      - file.links
